# Credenciales de QA para los tests E2E de JARVEX.
# Copiá este archivo a .env y completá los valores reales.
# El runner lee directamente de process.env, NO de un archivo .env automáticamente —
# tenés que exportarlas (`source .env` con `set -a` o `export VAR=...`) antes de correr.

JX_TEST_EMAIL=tu-email@dominio.com
JX_TEST_PASSWORD=tu-password

# Opcional: URL distinta a la de prod
# JX_TEST_URL=https://jarvex-app.vercel.app/

# Opcional: correr en modo visible (headed) en lugar de headless
# HEADLESS=false
